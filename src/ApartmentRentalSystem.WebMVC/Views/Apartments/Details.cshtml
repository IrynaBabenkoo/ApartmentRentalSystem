@model ApartmentRentalSystem.Domain.Entities.Apartment

@{
    ViewData["Title"] = "Деталі оголошення";

    var latestPrice = Model.Pricings?
        .OrderByDescending(p => p.ValidFrom)
        .FirstOrDefault();

    var isOwner = User.Identity?.IsAuthenticated == true && User.IsInRole("Owner");
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var mapQuery = $"{Model.City}, {Model.Address}";
    var mapUrl = "https://www.google.com/maps/search/?api=1&query=" + Uri.EscapeDataString(mapQuery);

    var isBookedNow = (ViewBag.IsBookedNow as bool?) == true;
    DateTime? nextAvailableFrom = ViewBag.NextAvailableFrom as DateTime?;
    DateTime? nextReservationStart = ViewBag.NextReservationStart as DateTime?;

    var suggestedBookingStart = isBookedNow && nextAvailableFrom.HasValue
        ? nextAvailableFrom.Value
        : DateTime.Today;

    var bookingReturnUrl = Url.Action("Create", "Reservations", new
    {
        apartmentId = Model.Id,
        startAt = suggestedBookingStart.ToString("yyyy-MM-dd")
    }) ?? "/";
}

<section class="page-header mb-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <div class="d-flex align-items-center flex-wrap gap-2 mb-2">
                <h1 class="page-title mb-0">@Model.Title</h1>

                @if (!Model.IsActive)
                {
                    <span class="details-status-chip details-status-chip-inactive">
                        Неактивне
                    </span>
                }
                else if (isBookedNow)
                {
                    <span class="details-status-chip details-status-chip-booked">
                        Заброньовано
                    </span>
                }
                else
                {
                    <span class="details-status-chip details-status-chip-available">
                        Доступне
                    </span>
                }
            </div>

            <p class="page-subtitle mb-0">
                <i class="fa-solid fa-location-dot me-1 text-primary"></i>
                @Model.City, @Model.Address
            </p>

            @if (!isOwner && Model.IsActive)
            {
                @if (isBookedNow && nextAvailableFrom.HasValue)
                {
                    <div class="details-status-note mt-3">
                        Найближча дата для бронювання —
                        <strong>@nextAvailableFrom.Value.ToString("dd.MM.yyyy")</strong>.
                    </div>
                }
                else if (!isBookedNow && nextReservationStart.HasValue)
                {
                    <div class="details-status-note mt-3">
                        Наступне бронювання починається з
                        <strong>@nextReservationStart.Value.ToString("dd.MM.yyyy")</strong>.
                    </div>
                }
            }
        </div>

        <div class="details-top-actions">
            @if (isOwner)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-4 fw-bold">
                    <i class="fa-solid fa-pen me-2"></i>Редагувати
                </a>
            }

            <a asp-action="Index" class="btn btn-outline-primary px-4 fw-bold">
                <i class="fa-solid fa-arrow-left me-2"></i>Назад
            </a>
        </div>
    </div>
</section>

<div class="row g-4 details-page-grid">
    <div class="col-lg-8">
        <div class="details-photo-shell">
            <div class="details-photo-frame">
                <img src="@(string.IsNullOrWhiteSpace(Model.ImagePath) ? "/images/apartments/default-apartment.jpg" : Model.ImagePath)"
                     alt="@Model.Title"
                     class="details-main-image" />
            </div>
        </div>

        <section class="home-section-card details-main-card">
            <h3 class="details-section-title mb-3">Про об'єкт</h3>

            <div class="details-info-grid mb-4">
                <div class="details-info-item">
                    <span class="details-info-label">Тип житла</span>
                    <span class="details-info-value">@(Model.HousingType?.Name ?? "Не вказано")</span>
                </div>

                <div class="details-info-item">
                    <span class="details-info-label">Макс. гостей</span>
                    <span class="details-info-value">@Model.MaxGuests</span>
                </div>

                <div class="details-info-item">
                    <span class="details-info-label">Площа</span>
                    <span class="details-info-value">
                        @(Model.Area.HasValue ? $"{Model.Area} м²" : "Не вказано")
                    </span>
                </div>

                <div class="details-info-item">
                    <span class="details-info-label">Адреса</span>
                    <span class="details-info-value">@Model.City, @Model.Address</span>
                </div>
            </div>

            <h4 class="details-subtitle mb-2">Опис</h4>
            <p class="details-description mb-4">
                @(string.IsNullOrWhiteSpace(Model.Description)
                    ? "Опис поки що не додано."
                    : Model.Description)
            </p>

            <h4 class="details-subtitle mb-3">Зручності</h4>

            @if (Model.ApartmentAmenities != null && Model.ApartmentAmenities.Any())
            {
                <div class="details-amenities">
                    @foreach (var item in Model.ApartmentAmenities.OrderBy(x => x.Amenity.Name))
                    {
                        <span class="details-amenity-chip">
                            <i class="fa-solid fa-check text-primary me-2"></i>@item.Amenity.Name
                        </span>
                    }
                </div>
            }
            else
            {
                <p class="text-muted mb-0">Зручності не вказані.</p>
            }
        </section>
    </div>

    <div class="col-lg-4">
        <section class="home-section-card details-side-card mb-4">
            <h3 class="details-section-title mb-3">Ціна</h3>

            @if (latestPrice != null)
            {
                <div class="details-price-value mb-1">
                    @latestPrice.Amount @latestPrice.Currency
                </div>
                <div class="text-muted mb-4">
                    за @(latestPrice.PriceType?.TimeUnit?.Name?.ToLower() ?? "період")
                </div>
            }
            else
            {
                <div class="text-muted mb-4">Ціна не вказана</div>
            }

            @if (isOwner)
            {
                <div class="d-grid gap-2">
                    <a asp-controller="Reservations" asp-action="Index" class="btn btn-outline-primary rounded-pill fw-bold">
                        <i class="fa-solid fa-calendar-check me-2"></i>Переглянути бронювання
                    </a>
                </div>
            }
            else if (!isAuthenticated)
            {
                <div class="details-auth-box">
                    <p class="details-auth-text mb-3">
                        Увійдіть, щоб оформити бронювання.
                    </p>

                    <div class="d-grid">
                        <a href="/Identity/Account/Login?returnUrl=@Uri.EscapeDataString(bookingReturnUrl)"
                           class="btn btn-primary rounded-pill fw-bold">
                            <i class="fa-solid fa-right-to-bracket me-2"></i>Увійти
                        </a>
                    </div>
                </div>
            }
            else
            {
                <div class="d-grid">
                    <a asp-controller="Reservations"
                       asp-action="Create"
                       asp-route-apartmentId="@Model.Id"
                       asp-route-startAt="@suggestedBookingStart.ToString("yyyy-MM-dd")"
                       class="btn btn-primary rounded-pill fw-bold">
                        <i class="fa-solid fa-calendar-plus me-2"></i>
                        @(isBookedNow && nextAvailableFrom.HasValue
                            ? $"Забронювати з {nextAvailableFrom.Value:dd.MM.yyyy}"
                            : "Забронювати")
                    </a>
                </div>
            }
        </section>

        <section class="home-section-card details-side-card">
            <h3 class="details-section-title mb-3">Локація</h3>

            <p class="text-muted mb-3">
                <i class="fa-solid fa-location-dot text-primary me-2"></i>
                @Model.City, @Model.Address
            </p>

            <a href="@mapUrl" target="_blank" rel="noopener noreferrer" class="btn btn-outline-primary rounded-pill fw-bold w-100">
                <i class="fa-solid fa-map-location-dot me-2"></i>Відкрити в Google Maps
            </a>
        </section>
    </div>
</div>