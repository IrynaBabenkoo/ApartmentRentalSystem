@model ApartmentRentalSystem.Domain.Entities.Reservation

@{
    var isOwner = User.Identity?.IsAuthenticated == true && User.IsInRole("Owner");
    ViewData["Title"] = isOwner ? "Редагувати бронювання" : "Змінити бронювання";
}

<section class="page-header mb-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h1 class="page-title mb-1">
                @(isOwner ? "Редагувати бронювання" : "Змінити бронювання")
            </h1>
            <p class="page-subtitle mb-0">
                @(isOwner
                    ? "Оновіть параметри бронювання та збережіть зміни."
                    : "За потреби змініть параметри свого бронювання.")
            </p>
        </div>

        <div class="details-top-actions">
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-primary px-4 fw-bold">
                <i class="fa-solid fa-arrow-left me-2"></i>Назад
            </a>
        </div>
    </div>
</section>

<div class="row justify-content-center mb-5">
    <div class="col-lg-8">
        <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
            <div class="card-header bg-primary py-5 d-flex align-items-center justify-content-center reservation-hero-header">
                <div class="bg-white rounded-circle d-flex align-items-center justify-content-center shadow-sm reservation-hero-icon">
                    <i class="fa-solid fa-pen-to-square fa-2x text-primary"></i>
                </div>
            </div>

            <div class="card-body p-5 bg-white">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-4 fw-bold"></div>

                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="GuestId" />

                    <div class="row">
                        <div class="col-12 mb-3">
                            <div class="form-floating">
                                <select asp-for="ApartmentId"
                                        class="form-select border-light shadow-sm form-soft-bg"
                                        asp-items="ViewBag.ApartmentId">
                                </select>
                                <label class="text-muted">Житло</label>
                                <span asp-validation-for="ApartmentId" class="text-danger small"></span>
                            </div>
                        </div>

                        @if (isOwner)
                        {
                            <div class="col-12 mb-3">
                                <div class="form-floating">
                                    <select asp-for="StatusId"
                                            class="form-select border-light shadow-sm form-soft-bg"
                                            asp-items="ViewBag.StatusId">
                                    </select>
                                    <label class="text-muted">Статус</label>
                                    <span asp-validation-for="StatusId" class="text-danger small"></span>
                                </div>
                            </div>
                        }
                        else
                        {
                            <input type="hidden" asp-for="StatusId" />
                        }

                        <div class="col-md-6 mb-3">
                            <div class="form-floating">
                                <select asp-for="UnitId"
                                        class="form-select border-light shadow-sm form-soft-bg"
                                        asp-items="ViewBag.UnitId">
                                </select>
                                <label class="text-muted">Одиниця часу</label>
                                <span asp-validation-for="UnitId" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <div class="form-floating">
                                <input asp-for="UnitsCount"
                                       type="number"
                                       min="1"
                                       class="form-control border-light shadow-sm form-soft-bg"
                                       placeholder="Кількість" />
                                <label class="text-muted">Кількість</label>
                                <span asp-validation-for="UnitsCount" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <div class="form-floating">
                                <input asp-for="StartAt"
                                       type="date"
                                       class="form-control border-light shadow-sm form-soft-bg" />
                                <label class="text-muted">Дата заїзду</label>
                                <span asp-validation-for="StartAt" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <div class="form-floating">
                                <input asp-for="EndAt"
                                       type="date"
                                       class="form-control border-light shadow-sm form-soft-bg" />
                                <label class="text-muted">Дата виїзду</label>
                                <span asp-validation-for="EndAt" class="text-danger small"></span>
                            </div>
                        </div>

                        @if (isOwner)
                        {
                            <div class="col-md-4 mb-3">
                                <div class="form-floating">
                                    <input asp-for="UnitAmountSnapshot"
                                           type="number"
                                           step="0.01"
                                           class="form-control border-light shadow-sm form-soft-bg"
                                           placeholder="Ціна за одиницю" />
                                    <label class="text-muted">Ціна за одиницю</label>
                                    <span asp-validation-for="UnitAmountSnapshot" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-4 mb-3">
                                <div class="form-floating">
                                    <input asp-for="CurrencySnapshot"
                                           class="form-control border-light shadow-sm form-soft-bg"
                                           placeholder="Валюта" />
                                    <label class="text-muted">Валюта</label>
                                    <span asp-validation-for="CurrencySnapshot" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-4 mb-3">
                                <div class="form-floating">
                                    <input asp-for="TotalPrice"
                                           type="number"
                                           step="0.01"
                                           class="form-control border-light shadow-sm form-soft-bg"
                                           placeholder="Загальна вартість" />
                                    <label class="text-muted">Загальна вартість</label>
                                    <span asp-validation-for="TotalPrice" class="text-danger small"></span>
                                </div>
                            </div>
                        }
                        else
                        {
                            <input type="hidden" asp-for="UnitAmountSnapshot" />
                            <input type="hidden" asp-for="CurrencySnapshot" />
                            <input type="hidden" asp-for="TotalPrice" />
                        }

                        <input type="hidden" asp-for="PriceTypeIdSnapshot" />
                    </div>

                    <div class="reservation-note-box mt-3 mb-4">
                        @(isOwner
                            ? "За потреби власник може змінити статус та уточнити параметри бронювання."
                            : "Змінюйте лише актуальні параметри своєї поїздки перед підтвердженням.")
                    </div>

                    <div class="d-grid gap-3">
                        <button type="submit" class="btn btn-primary rounded-pill py-3 fw-bold shadow-sm">
                            <i class="fa-solid fa-floppy-disk me-2"></i>ЗБЕРЕГТИ ЗМІНИ
                        </button>

                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-primary rounded-pill py-3 fw-bold">
                            <i class="fa-solid fa-arrow-left me-2"></i>Повернутися
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}