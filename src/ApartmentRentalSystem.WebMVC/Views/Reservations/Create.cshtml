@model ApartmentRentalSystem.Domain.Entities.Reservation

@{
    ViewData["Title"] = "Створити бронювання";
}

<section class="page-header mb-4">
    <div>
        <h1 class="page-title mb-1">Створити бронювання</h1>
        <p class="page-subtitle mb-0">
            Вкажіть параметри бронювання та підтвердьте свою поїздку.
        </p>
    </div>
</section>

<div class="row justify-content-center mb-5">
    <div class="col-lg-8">
        <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
            <div class="card-header bg-primary py-5 d-flex align-items-center justify-content-center reservation-hero-header">
                <div class="bg-white rounded-circle d-flex align-items-center justify-content-center shadow-sm reservation-hero-icon">
                    <i class="fa-solid fa-calendar-plus fa-2x text-primary"></i>
                </div>
            </div>

            <div class="card-body p-5 bg-white">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-4 fw-bold"></div>

                <form asp-action="Create" method="post">
                    <div class="row">
                        <div class="col-12 mb-3">
                            <div class="form-floating">
                                <select asp-for="ApartmentId"
                                        class="form-select border-light shadow-sm form-soft-bg"
                                        asp-items="ViewBag.ApartmentId">
                                    <option value="">-- Оберіть житло --</option>
                                </select>
                                <label class="text-muted">Житло</label>
                                <span asp-validation-for="ApartmentId" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <div class="form-floating">
                                <select asp-for="UnitId"
                                        class="form-select border-light shadow-sm form-soft-bg"
                                        asp-items="ViewBag.UnitId">
                                    <option value="">-- Оберіть період --</option>
                                </select>
                                <label class="text-muted">Одиниця часу</label>
                                <span asp-validation-for="UnitId" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <div class="form-floating">
                                <input asp-for="UnitsCount"
                                       type="number"
                                       min="1"
                                       class="form-control border-light shadow-sm form-soft-bg"
                                       placeholder="Кількість" />
                                <label class="text-muted">Кількість</label>
                                <span asp-validation-for="UnitsCount" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <div class="form-floating">
                                <input asp-for="StartAt"
                                       type="date"
                                       class="form-control border-light shadow-sm form-soft-bg" />
                                <label class="text-muted">Дата заїзду</label>
                                <span asp-validation-for="StartAt" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <div class="form-floating">
                                <input asp-for="EndAt"
                                       type="date"
                                       class="form-control border-light shadow-sm form-soft-bg" />
                                <label class="text-muted">Дата виїзду</label>
                                <span asp-validation-for="EndAt" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="reservation-note-box mt-3 mb-4">
                        Після створення бронювання система автоматично визначить статус, ціну за одиницю та загальну вартість.
                    </div>

                    <div class="d-grid gap-3">
                        <button type="submit" class="btn btn-primary rounded-pill py-3 fw-bold shadow-sm">
                            <i class="fa-solid fa-check me-2"></i>ПІДТВЕРДИТИ БРОНЮВАННЯ
                        </button>

                        <a asp-action="Index" class="btn btn-outline-primary rounded-pill py-3 fw-bold">
                            <i class="fa-solid fa-arrow-left me-2"></i>Назад до списку
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}