@model IEnumerable<ApartmentRentalSystem.Domain.Entities.Reservation>

@{
    ViewData["Title"] = "Бронювання";
}

<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary fw-bold">Список бронювань</h2>
        <a asp-action="Create" class="btn btn-primary shadow-sm">Створити нове бронювання</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">Початок / Кінець</th>
                        <th>К-ть</th>
                        <th>Житло</th>
                        <th>Гість</th>
                        <th>Ціна (Разом)</th>
                        <th>Статус</th>
                        <th class="text-end pe-3">Дії</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-3">
                                <div class="small">@item.StartAt.ToShortDateString()</div>
                                <div class="small text-muted">@item.EndAt.ToShortDateString()</div>
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.UnitsCount)
                                <span class="small text-muted">(@item.TimeUnit.Name)</span>
                            </td>
                            <td>
                                <div class="fw-bold text-truncate" style="max-width: 150px;">
                                    @Html.DisplayFor(modelItem => item.Apartment.Address)
                                </div>
                            </td>
                            <td>
                                <small>@Html.DisplayFor(modelItem => item.Guest.Email)</small>
                            </td>
                            <td>
                                <span class="fw-bold">@item.TotalPrice @item.CurrencySnapshot</span>
                                <div class="x-small text-muted" style="font-size: 0.75rem;">
                                    @item.UnitAmountSnapshot за од.
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-info text-dark">
                                    @Html.DisplayFor(modelItem => item.Status.Name)
                                </span>
                            </td>
                            <td class="text-end pe-3">
                                <div class="btn-group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Змінити</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Деталі</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Видалити</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>