@model IEnumerable<ApartmentRentalSystem.Domain.Entities.Reservation>

@{
    ViewData["Title"] = ViewBag.PageTitle ?? "Бронювання";
    bool isOwner = ViewBag.IsOwner ?? false;
    string pageTitle = ViewBag.PageTitle ?? "Бронювання";
    string pageSubtitle = ViewBag.PageSubtitle ?? "Переглядайте свої бронювання.";
    string emptyTitle = ViewBag.EmptyTitle ?? "Поки що немає бронювань";
    string emptySubtitle = ViewBag.EmptySubtitle ?? "Бронювання з’являться тут.";
}

<section class="page-header mb-4">
    <div>
        <h1 class="page-title mb-1">@pageTitle</h1>
        <p class="page-subtitle mb-0">@pageSubtitle</p>
    </div>
</section>

<section class="home-section-card mb-5">
    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table align-middle reservations-table mb-0">
                <thead>
                    <tr>
                        <th>Заїзд / Виїзд</th>
                        <th>Період</th>
                        <th>Житло</th>

                        @if (isOwner)
                        {
                            <th>Гість</th>
                        }

                        <th>Ціна (разом)</th>
                        <th>Статус</th>
                        <th class="text-end">Дії</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var statusName = item.Status?.Name ?? "Невідомо";
                        var badgeClass = "reservation-status reservation-status-neutral";

                        if (statusName == "Очікує підтвердження")
                        {
                            badgeClass = "reservation-status reservation-status-pending";
                        }
                        else if (statusName == "Підтверджено")
                        {
                            badgeClass = "reservation-status reservation-status-approved";
                        }
                        else if (statusName == "Скасовано")
                        {
                            badgeClass = "reservation-status reservation-status-cancelled";
                        }

                        <tr>
                            <td>
                                <div class="fw-semibold">
                                    @item.StartAt.ToString("dd.MM.yyyy")
                                </div>
                                <div class="text-muted small">
                                    @item.EndAt.ToString("dd.MM.yyyy")
                                </div>
                            </td>

                            <td>
                                <div class="fw-semibold reservation-period-text">
                                    @item.UnitsCount @(item.TimeUnit?.Name?.ToLower() ?? "од.")
                                </div>
                            </td>

                            <td>
                                <div class="fw-semibold">
                                    @(item.Apartment?.Title ?? "—")
                                </div>
                            </td>

                            @if (isOwner)
                            {
                                <td>
                                    <div class="fw-semibold">
                                        @(item.Guest?.Email ?? $"ID: {item.GuestId}")
                                    </div>
                                </td>
                            }

                            <td>
                                <span class="fw-semibold text-primary">
                                    @(item.TotalPrice?.ToString("0.##") ?? "—")
                                    @if (!string.IsNullOrWhiteSpace(item.CurrencySnapshot))
                                    {
                                        @item.CurrencySnapshot
                                    }
                                </span>
                            </td>

                            <td>
                                <span class="@badgeClass">
                                    @statusName
                                </span>
                            </td>

                            <td class="text-end">
                                @if (isOwner)
                                {
                                    <div class="d-inline-flex gap-2 flex-wrap justify-content-end">
                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-outline-primary btn-sm px-3" title="Деталі">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>

                                        @if (statusName == "Очікує підтвердження")
                                        {
                                            <form asp-action="Confirm" asp-route-id="@item.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-outline-primary btn-sm px-3" title="Підтвердити">
                                                    <i class="fa-solid fa-check"></i>
                                                </button>
                                            </form>

                                            <form asp-action="Reject" asp-route-id="@item.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-outline-secondary btn-sm px-3" title="Відхилити">
                                                    <i class="fa-solid fa-xmark"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-outline-primary btn-sm px-3" title="Деталі">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>

                                        <a asp-action="Delete" asp-route-id="@item.Id"
                                           class="btn btn-outline-primary btn-sm px-3" title="Скасувати бронювання">
                                            <i class="fa-solid fa-xmark"></i>
                                        </a>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div class="empty-icon mx-auto mb-3">
                <i class="fa-solid fa-calendar-xmark"></i>
            </div>

            <h5 class="fw-bold text-dark">@emptyTitle</h5>
            <p class="text-muted mb-0">
                @emptySubtitle
            </p>
        </div>
    }
</section>