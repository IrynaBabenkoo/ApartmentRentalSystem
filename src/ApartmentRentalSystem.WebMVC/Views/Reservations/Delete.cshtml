@model ApartmentRentalSystem.Domain.Entities.Reservation

@{
    ViewData["Title"] = "Видалити";
}

<h1>Видалити</h1>

<h3>Ви впевнені, що хочете видалити це?</h3>
<div>
    <h4>Бронювання</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.UnitsCount)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.UnitsCount)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.StartAt)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.StartAt)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.EndAt)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.EndAt)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.PriceTypeIdSnapshot)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.PriceTypeIdSnapshot)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.UnitAmountSnapshot)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.UnitAmountSnapshot)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.CurrencySnapshot)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.CurrencySnapshot)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.TotalPrice)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.TotalPrice)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Apartment)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Apartment.Address)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Guest)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Guest.Email)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Status)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Status.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.TimeUnit)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.TimeUnit.Name)
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Видалити" class="btn btn-danger" /> |
        <a asp-action="Index">Назад до списку</a>
    </form>
</div>