        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.StartAt)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.EndAt)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.EndAt)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.PriceTypeIdSnapshot)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.PriceTypeIdSnapshot)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.UnitAmountSnapshot)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.UnitAmountSnapshot)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.CurrencySnapshot)
