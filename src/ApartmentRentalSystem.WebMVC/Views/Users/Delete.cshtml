@model ApartmentRentalSystem.Domain.Entities.User

@{
    ViewData["Title"] = "Видалити користувача";

    var roleName = Model.Role?.Name ?? "Користувач";
    if (roleName == "Host")
    {
        roleName = "Власник";
    }
    else if (roleName == "Guest")
    {
        roleName = "Орендар";
    }
}

<section class="page-header mb-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h1 class="page-title mb-1">Видалити користувача</h1>
            <p class="page-subtitle mb-0">
                Перевірте інформацію перед видаленням запису.
            </p>
        </div>

        <div class="details-top-actions">
            <a asp-action="Index" class="btn btn-outline-primary px-4 fw-bold">
                <i class="fa-solid fa-arrow-left me-2"></i>Назад
            </a>
        </div>
    </div>
</section>

<div class="row g-4 mb-5">
    <div class="col-lg-8">
        <section class="home-section-card h-100">
            <h3 class="details-section-title mb-3">Інформація про користувача</h3>

            <div class="details-info-grid">
                <div class="details-info-item">
                    <span class="details-info-label">Повне ім’я</span>
                    <span class="details-info-value">@Model.FullName</span>
                </div>

                <div class="details-info-item">
                    <span class="details-info-label">Електронна пошта</span>
                    <span class="details-info-value">@Model.Email</span>
                </div>

                <div class="details-info-item">
                    <span class="details-info-label">Номер телефону</span>
                    <span class="details-info-value">
                        @(string.IsNullOrWhiteSpace(Model.Phone) ? "Не вказано" : Model.Phone)
                    </span>
                </div>

                <div class="details-info-item">
                    <span class="details-info-label">Роль</span>
                    <span class="details-info-value">@roleName</span>
                </div>
            </div>
        </section>
    </div>

    <div class="col-lg-4">
        <section class="home-section-card details-side-card">
            <h3 class="details-section-title mb-3">Підтвердження видалення</h3>

            <p class="text-muted mb-4">
                Ця дія видалить користувача з таблиці системи.
            </p>

            <form asp-action="Delete" method="post" class="d-grid gap-2">
                <input type="hidden" asp-for="Id" />

                <button type="submit" class="btn btn-primary rounded-pill fw-bold">
                    <i class="fa-solid fa-trash me-2"></i>Видалити користувача
                </button>

                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-primary rounded-pill fw-bold">
                    <i class="fa-solid fa-arrow-left me-2"></i>Повернутися
                </a>
            </form>
        </section>
    </div>
</div>