@model ApartmentRentalSystem.Domain.Entities.User

@{
    ViewData["Title"] = "Мій профіль";
    var roleName = Model.Role?.Name ?? "Користувач";
    var roleBadgeClass = "profile-role-badge";

    if (roleName == "Host")
    {
        roleName = "Власник";
    }
    else if (roleName == "Guest")
    {
        roleName = "Орендар";
    }
}

<section class="page-header mb-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <div class="d-flex align-items-center flex-wrap gap-2 mb-2">
                <h1 class="page-title mb-0">Мій профіль</h1>
                <span class="@roleBadgeClass">@roleName</span>
            </div>

            <p class="page-subtitle mb-0">
                Переглядайте основну інформацію про свій акаунт.
            </p>
        </div>

        <div class="details-top-actions">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-4 fw-bold">
                <i class="fa-solid fa-pen me-2"></i>Редагувати
            </a>

            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary px-4 fw-bold">
                <i class="fa-solid fa-arrow-left me-2"></i>На головну
            </a>
        </div>
    </div>
</section>

<div class="row g-4 mb-5">
    <div class="col-lg-4">
        <section class="home-section-card text-center h-100 profile-side-card">
            <div class="profile-avatar mx-auto mb-3">
                <i class="fa-solid fa-user"></i>
            </div>

            <h3 class="profile-name mb-1">@Model.FullName</h3>
            <p class="text-muted mb-3">@Model.Email</p>

            <span class="@roleBadgeClass">@roleName</span>
        </section>
    </div>

    <div class="col-lg-8">
        <section class="home-section-card h-100">
            <h3 class="details-section-title mb-3">Основна інформація</h3>

            <div class="details-info-grid">
                <div class="details-info-item">
                    <span class="details-info-label">Повне ім’я</span>
                    <span class="details-info-value">@Model.FullName</span>
                </div>

                <div class="details-info-item">
                    <span class="details-info-label">Електронна пошта</span>
                    <span class="details-info-value">@Model.Email</span>
                </div>

                <div class="details-info-item">
                    <span class="details-info-label">Номер телефону</span>
                    <span class="details-info-value">
                        @(string.IsNullOrWhiteSpace(Model.Phone) ? "Не вказано" : Model.Phone)
                    </span>
                </div>

                <div class="details-info-item">
                    <span class="details-info-label">Роль</span>
                    <span class="details-info-value">@roleName</span>
                </div>
            </div>
        </section>
    </div>
</div>