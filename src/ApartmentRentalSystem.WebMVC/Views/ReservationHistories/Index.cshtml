@model IEnumerable<ApartmentRentalSystem.Domain.Entities.ReservationHistory>

@{
    ViewData["Title"] = "Історія бронювань";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary fw-bold">Історія змін бронювань</h2>
        <a asp-action="Create" class="btn btn-primary shadow-sm">Додати запис</a>
    </div>

    <div class="card shadow-sm border-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Тип зміни</th>
                    <th>Примітка</th>
                    <th>Дата зміни</th>
                    <th>ID Бронювання</th>
                    <th>Хто змінив</th>
                    <th class="text-end pe-4">Дії</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold">
                            @Html.DisplayFor(modelItem => item.ChangeType)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Note)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.ChangedAt)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Reservation.Id)
                        </td>
                        <td>
                            <small class="text-muted">@Html.DisplayFor(modelItem => item.ChangedBy.Email)</small>
                        </td>
                        <td class="text-end pe-4">
                            <div class="btn-group">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Змінити</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Деталі</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Видалити</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
