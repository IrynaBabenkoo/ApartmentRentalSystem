@model ApartmentRentalSystem.Domain.Entities.ReservationHistory

@{
    ViewData["Title"] = "Видалення запису історії";
}

<h1>Видалити</h1>

<h3 class="text-danger">Ви впевнені, що хочете видалити цей запис з історії?</h3>
<div>
    <h4>Історія бронювання</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ChangeType)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ChangeType)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Note)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Note)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ChangedAt)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ChangedAt)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Reservation)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Reservation.Id)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ChangedBy)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ChangedBy.Email)
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Видалити" class="btn btn-danger" /> |
        <a asp-action="Index" class="btn btn-secondary">Назад до списку</a>
    </form>
</div>