<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ApartmentRentalSystem</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap_pulse.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ApartmentRentalSystem.WebMVC.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-primary border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Оренда житла</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                       @*  <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Home" asp-action="Index">Головна</a>
                        </li> *@
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Users" asp-action="Index">Користувачі</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Apartments" asp-action="Index">Апартаменти</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Reservations" asp-action="Index">Бронювання</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Payments" asp-action="Index">Платежі</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Налаштування
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
                                <li><a class="dropdown-item" asp-controller="HousingTypes" asp-action="Index">Типи житла</a></li>
                                <li><a class="dropdown-item" asp-controller="UserRoles" asp-action="Index">Ролі</a></li>
                                <li><a class="dropdown-item" asp-controller="TimeUnits" asp-action="Index">Одиниці часу</a></li>
                                <li><a class="dropdown-item" asp-controller="PriceTypes" asp-action="Index">Типи цін</a></li>
                                <li><a class="dropdown-item" asp-controller="ApartmentPricings" asp-action="Index">Ціни об’єктів</a></li>
                                <li><a class="dropdown-item" asp-controller="PaymentMethods" asp-action="Index">Способи оплати</a></li>
                                <li><a class="dropdown-item" asp-controller="ReservationStatuses" asp-action="Index">Статуси бронювань</a></li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - ApartmentRentalSystem.WebMVC - <a asp-area="" asp-controller="Home" asp-action="Privacy">Конфіденційність</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>