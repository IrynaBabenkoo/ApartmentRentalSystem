@model ApartmentRentalSystem.Domain.Entities.UserRole

@{
    ViewData["Title"] = "Редагування ролі";
}

<h2>Редагувати роль</h2>
<hr />

<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label class="control-label fw-bold">Назва ролі</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Зберегти" class="btn btn-primary shadow-sm" />
                <a asp-action="Index" class="btn btn-link">Назад до списку</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}