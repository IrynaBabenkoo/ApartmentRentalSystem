@model IEnumerable<ApartmentRentalSystem.Domain.Entities.ApartmentPricing>

@{
    ViewData["Title"] = "Ціноутворення";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary fw-bold">Налаштування цін</h2>
        <a asp-action="Create" class="btn btn-primary shadow-sm">Додати нову ціну</a>
    </div>

    <table class="table table-hover border shadow-sm align-middle">
        <thead class="table-light">
            <tr>
                <th class="ps-4">Сума</th>
                <th>Валюта</th>
                <th>Діє з</th>
                <th>Діє до</th>
                <th>Адреса житла</th>
                <th>Тип періоду</th>
                <th class="text-end pe-4">Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="ps-4 fw-bold">
                        @Html.DisplayFor(modelItem => item.Amount)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Currency)
                    </td>
                    <td>
                        @item.ValidFrom.ToShortDateString()
                    </td>
                    <td>
                        @(item.ValidTo.HasValue ? item.ValidTo.Value.ToShortDateString() : "Необмежено")
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Apartment.Address)
                    </td>
                    <td>
                        <span>
                            @Html.DisplayFor(modelItem => item.PriceType.Name)
                        </span>
                    </td>
                    <td class="text-end pe-4">
                        <div class="btn-group">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Змінити</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Деталі</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Видалити</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>