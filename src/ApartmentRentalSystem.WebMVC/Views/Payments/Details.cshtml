@model ApartmentRentalSystem.Domain.Entities.Payment

@{
    ViewData["Title"] = "Деталі платежу";
}

<h1>Деталі</h1>

<div>
    <h4>Платіж</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Amount)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Amount)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Currency)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Currency)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.PaymentStatus)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.PaymentStatus)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.PaidAt)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.PaidAt)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Reservation)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Reservation.Id)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Method)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Method.Name)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">Редагувати</a> |
    <a asp-action="Index">Назад до списку</a>
</div>